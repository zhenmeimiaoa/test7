<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📝 病症录入"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1976D2"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvIdentityInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="当前患者：未知"
        android:textSize="14sp"
        android:textColor="#4CAF50"
        android:padding="8dp"
        android:background="#E8F5E9"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="请描述症状（支持语音输入）："
        android:textSize="16sp"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etSymptom"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:hint="例如：最近三天咳嗽，伴有低烧，喉咙痛..."
        android:gravity="top"
        android:padding="12dp"
        android:background="@android:drawable/edit_text"
        android:textSize="16sp"/>

    <Button
        android:id="@+id/btnVoiceInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎤 语音输入"
        android:textSize="16sp"
        android:padding="12dp"
        android:layout_marginTop="8dp"
        android:backgroundTint="#FF9800"/>

    <Button
        android:id="@+id/btnAiAnalyze"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🤖 AI分析症状"
        android:textSize="16sp"
        android:padding="12dp"
        android:layout_marginTop="8dp"
        android:backgroundTint="#9C27B0"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/tvAiResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="14sp"
        android:padding="12dp"
        android:background="#FFFFFF"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        android:scrollbars="vertical"
        android:maxHeight="200dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="💾 保存病症信息"
        android:textSize="18sp"
        android:padding="16dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#4CAF50"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="返回"
            android:backgroundTint="#757575"/>

        <Button
            android:id="@+id/btnLogs"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="查看日志"
            android:backgroundTint="#9E9E9E"/>
    </LinearLayout>

</LinearLayout>
